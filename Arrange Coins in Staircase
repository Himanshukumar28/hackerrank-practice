import java.io.*;
import java.util.*;

public class Solution {

    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
            int n = sc.nextInt();
           System.out.println(stair(n));
    }
    public static int stair(int n){
         for(long i =1; i<=n; i++){
            long sum = i*(i+1)/2;

            if(sum == n) return (int) i;
            if(sum > n) return (int) i -1;
        }
        return 0;
    }
}
